# AI Code Fixes Configuration
# This file configures the automated AI code fixing workflow

# Feature ID to use for SDLC flow testing
FEATURE_ID=feature-001-support-ticket

# Maximum number of fix attempts
MAX_FIX_ATTEMPTS=3

# Whether to create PRs for fixes
CREATE_FIX_PRS=true

# Whether to auto-merge PRs if tests pass
AUTO_MERGE_SUCCESSFUL_FIXES=false

# Labels to apply to fix PRs
FIX_PR_LABELS=ai-generated,automated-fix,needs-review

# Error patterns to detect and fix
ENABLE_SPRING_BOOT_FIXES=true
ENABLE_REACT_TESTING_FIXES=true
ENABLE_NPM_DEPENDENCY_FIXES=true
ENABLE_ESLINT_FIXES=true

# Notification settings
NOTIFY_ON_SUCCESS=true
NOTIFY_ON_FAILURE=true
SLACK_WEBHOOK_URL=

# GitHub settings
PR_ASSIGNEE=auto  # 'auto' assigns to the commit author
PR_REVIEWERS=

# AI/LLM settings
USE_GITHUB_COPILOT=true
FALLBACK_TO_PATTERN_MATCHING=true

# Safety settings
SKIP_IF_BOT_COMMIT=true
REQUIRED_STATUS_CHECKS=
MAX_FILES_CHANGED=50