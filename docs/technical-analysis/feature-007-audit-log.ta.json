{
  "meta": {
    "featureId": "feature-007-audit-log",
    "title": "Feature-007: Audit log voor gebruikersacties",
    "version": "1.0.0"
  },
  "scope": {
    "inScope": [
      "Event publiceren bij inloggen en uitloggen van een gebruiker",
      "Event publiceren bij aanmaken, wijzigen en verwijderen van een resource",
      "Audit log consumer slaat events op in een audit-database",
      "Retry logica bij mislukte opslag",
      "Dead letter queue voor onverwerkte events"
    ],
    "outOfScope": [
      "UI voor het raadplegen van de audit log",
      "Exporteren van audit logs naar externe systemen",
      "Real-time alerting op basis van audit events",
      "Compliancerapportage"
    ]
  },
  "assumptions": [],
  "openQuestions": [],
  "requirements": [
    {
      "id": "REQ-001",
      "text": "Bij elke inlogpoging (geslaagd of mislukt) wordt een UserLoginEvent gepubliceerd.",
      "priority": "must"
    },
    {
      "id": "REQ-002",
      "text": "Bij uitloggen wordt een UserLogoutEvent gepubliceerd.",
      "priority": "must"
    },
    {
      "id": "REQ-003",
      "text": "Bij het aanmaken van een resource wordt een ResourceCreatedEvent gepubliceerd.",
      "priority": "must"
    },
    {
      "id": "REQ-004",
      "text": "Bij het wijzigen van een resource wordt een ResourceUpdatedEvent gepubliceerd met het oude en nieuwe veld.",
      "priority": "must"
    },
    {
      "id": "REQ-005",
      "text": "Bij het verwijderen van een resource wordt een ResourceDeletedEvent gepubliceerd.",
      "priority": "must"
    },
    {
      "id": "REQ-006",
      "text": "De AuditLogConsumer verwerkt alle events en slaat ze op in de audit-database.",
      "priority": "must"
    },
    {
      "id": "REQ-007",
      "text": "Elk audit event bevat een correlationId, userId, timestamp en actieomschrijving.",
      "priority": "must"
    },
    {
      "id": "REQ-008",
      "text": "Bij een mislukte opslag wordt het event opnieuw geprobeerd met exponential backoff (max 3 pogingen).",
      "priority": "must"
    },
    {
      "id": "REQ-009",
      "text": "Events die na 3 pogingen niet verwerkt kunnen worden, gaan naar de dead letter queue.",
      "priority": "must"
    },
    {
      "id": "REQ-010",
      "text": "Audit events zijn immutable \u2014 ze mogen nooit gewijzigd of verwijderd worden.",
      "priority": "must"
    },
    {
      "id": "REQ-011",
      "text": "Elk event krijgt een unieke eventId (UUID) toegewezen bij publicatie.",
      "priority": "must"
    },
    {
      "id": "REQ-012",
      "text": "Events zijn idempotent \u2014 dubbele verwerking heeft geen side-effects dankzij eventId deduplicatie.",
      "priority": "must"
    },
    {
      "id": "REQ-013",
      "text": "Event publicatie mag de response tijd van de primaire API niet met meer dan 20ms verhogen.",
      "priority": "must"
    },
    {
      "id": "REQ-014",
      "text": "De consumer moet minimaal 500 events per seconde kunnen verwerken.",
      "priority": "must"
    },
    {
      "id": "REQ-015",
      "text": "Audit logs moeten minimaal 2 jaar bewaard worden.",
      "priority": "must"
    }
  ],
